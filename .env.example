# ═══════════════════════════════════════════════════════════════
# Backend — LOCAL DEVELOPMENT env
# Copy this file to .env (same folder) and tweak as needed.
# Never commit the real .env file.
# ═══════════════════════════════════════════════════════════════

# ── Database (local Docker Postgres) ───────────────────────────
DATABASE_URL=postgresql://ibhighway:ibhighway123@localhost:5432/ibhighway

# ── Auth secret ────────────────────────────────────────────────
# Generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_before_production

# ── Port ───────────────────────────────────────────────────────
PORT=3001

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── App base URL ───────────────────────────────────────────────
# Used when building registration links the admin emails to parents
# (e.g. https://ibphysicswithrao.com/home/ibhighway in production).
APP_BASE_URL=http://localhost:5173

# ── Razorpay (test mode) ───────────────────────────────────────
# Leave as "rzp_test_sandbox" to run fully mocked locally; the app
# will auto-confirm sandbox payments. To test a real checkout
# popup with test cards, drop real test keys here (they start with
# rzp_test_...) from https://dashboard.razorpay.com/app/keys.
RAZORPAY_KEY_ID=rzp_test_sandbox
RAZORPAY_KEY_SECRET=sandbox_secret

# ── Email / SMTP (optional for local dev) ──────────────────────
# Leave these blank to log emails to the terminal instead of sending.
# For Gmail: use an App Password (16 chars), not your real password.
# https://support.google.com/mail/answer/185833
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IBHighway <noreply@ibphysicswithrao.com>
ADMIN_EMAIL=
