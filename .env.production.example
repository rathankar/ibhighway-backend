# ═══════════════════════════════════════════════════════════════
# Backend — PRODUCTION env. Set these as environment variables on
# Render (Dashboard → Your Service → Environment → Add Variable).
# DO NOT commit real values to git.
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production

# ── Database (Supabase) ────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Auth secret (REQUIRED — app won't start without it) ────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=https://ibhighway.com,https://www.ibhighway.com

# ── App base URL (used in registration + approval emails) ───────
APP_BASE_URL=https://ibhighway.com

# ── Razorpay ────────────────────────────────────────────────────
# Use test keys (rzp_test_...) first; swap to live (rzp_live_...) after KYC.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Email / SMTP ────────────────────────────────────────────────
# Easy: Gmail + 16-char App Password (enable 2FA → App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IBHighway <noreply@ibhighway.com>

# Where admin notifications are sent (lead alerts, new teacher applications)
ADMIN_EMAIL=rathankar@gmail.com

# ── ElevenLabs (AI outbound calling) ───────────────────────────
# Get from: elevenlabs.io → API Keys
# Agent ID: create a Conversational AI agent → copy its ID
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ── Twilio (WhatsApp, SMS, and deadline reminder voice calls) ────
# Get from: twilio.com → Account → Dashboard
# IMPORTANT: Enable India (+91) in Twilio Console → Voice → Settings → Geo Permissions
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=            # Your purchased US number, e.g. +12025551234
# Used for: no-show alerts, mentor WhatsApp delivery, deadline reminder voice calls

# ── Telegram Bot ────────────────────────────────────────────────
# Get from: @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=

# ── Cloudinary (teacher profile photo uploads) ──────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# ── Log level ──────────────────────────────────────────────────
LOG_LEVEL=info
